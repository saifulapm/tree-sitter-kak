{
  "name": "tree-sitter-kakscript",
  "version": "0.1.0",
  "description": "Kakscript grammar for tree-sitter",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saiful/kakscript-tree-sitter.git"
  },
  "license": "MIT",
  "author": {
    "name": "Saiful"
  },
  "main": "bindings/node/index.mjs",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "kakscript"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "dependencies": {
    "node-addon-api": "^8.5.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "prebuildify": "^6.0.1",
    "tree-sitter-cli": "^0.26.3"
  },
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.mjs"
  }
}
